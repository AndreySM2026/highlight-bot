BOT_TOKEN=your_telegram_bot_token
TIMEWEB_API_TOKEN=your_timeweb_api_token
TIMEWEB_AGENT_ID=your_agent_uuid

# Локально: USE_POLLING=1 и пустой WEBHOOK_URL
# Production (Timeweb): USE_POLLING не задавать, WEBHOOK_URL=https://your-app.timeweb.cloud
USE_POLLING=1
WEBHOOK_URL=
WEBHOOK_SECRET=change_me_to_random_32_chars

# Если api.telegram.org недоступен (типично в РФ без VPN):
# TELEGRAM_PROXY=socks5://user:pass@host:1080
# или свой Bot API на VPS: TELEGRAM_API_BASE_URL=http://your-vps:8081
TELEGRAM_PROXY=
TELEGRAM_API_BASE_URL=

HOST=0.0.0.0
PORT=8080

DATABASE_PATH=/app/data/bot.db
TEMP_DIR=/app/data/temp

MAX_VIDEO_DURATION_SEC=3600
MAX_UPLOAD_BYTES=20971520
RUTUBE_ENABLED=1
VK_ENABLED=1
MAX_RUTUBE_DOWNLOAD_BYTES=1073741824
RUTUBE_MAX_HEIGHT=1080
MAX_CLIPS=10
MAX_VIDEOS_PER_DAY=10
MIN_CLIP_SEC=15
MAX_CLIP_SEC=60

TARGET_WIDTH=1080
TARGET_HEIGHT=1920

# Whisper (распознавание речи для выбора хайлайтов)
WHISPER_ENABLED=1
WHISPER_MODEL=small
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Центровка 9:16 по лицу (OpenCV)
FACE_CROP_ENABLED=1

# Вшитые субтитры (кнопка при рендере; нужен Whisper)
SUBTITLES_ENABLED=1
SUBTITLES_ALIGNMENT=5
SUBTITLES_MARGIN_V=80
